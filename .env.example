# Copia este archivo a .env y rellena los valores. No subas .env a git.
# En el servidor: cp .env.example .env && nano .env

# Obligatorio en producción (generar con: openssl rand -hex 32)
SECRET_KEY=CHANGE_THIS_TO_256_BIT_SECRET

# Entorno (development | production)
APP_ENV=production

# URL del portal (con barra final). Si el portal está en un subpath, úsalo aquí (ej. https://dominio.com/portal/)
# Así las apps redirigen al login correcto y el portal genera enlaces bien.
PORTAL_URL=https://hidalgotech.com/

# Usuario y contraseña del primer admin (cámbialos en producción)
DEFAULT_ADMIN_USER=admin
DEFAULT_ADMIN_PASSWORD=CambiaEstoPorUnaContraseñaSegura123!
